# SEC EDGAR API - Required
# Format: "Your Name your.email@example.com"
# SEC requires a valid user agent for API access
EDGAR_USER_AGENT="Your Name your.email@example.com"

# EDGAR API base URL (default: EDGAR full-text search)
EDGAR_BASE_URL="https://efts.sec.gov/LATEST"

# EDGAR filing archive base URL
EDGAR_ARCHIVE_URL="https://www.sec.gov/Archives/edgar/data"

# Local data directory for downloaded filings
DATA_DIR="./data/raw"

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# Rate limiting: max requests per second to EDGAR (SEC limit is 10)
EDGAR_MAX_RPS=10

# ─── LLM Generation (required for answers) ────────────────────────────────────
# Google Gemini API key — required for RAGGenerator and LLM-as-Judge
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your-google-api-key"

# ─── Langfuse Observability (optional) ────────────────────────────────────────
# Distributed tracing, cost tracking, and production metrics.
# Leave blank to disable tracing (the system runs fine without it).
# Get yours at: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# ─── FastAPI Settings ──────────────────────────────────────────────────────────
# API key for the /query and /ingest endpoints (leave blank to disable auth)
FINRAG_API_KEY=""
# Set to "true" to initialize the full RAG pipeline on startup
FINRAG_INIT_PIPELINE="false"
FINRAG_MAX_SESSIONS=1000
FINRAG_PROMPT_VERSION="v1"
# Comma-separated allowed CORS origins (* = all)
FINRAG_CORS_ORIGINS="*"
