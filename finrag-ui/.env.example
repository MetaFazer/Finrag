# ── FinRAG Frontend Environment Variables ─────────────────────

# Backend URL (server-side proxy routes use this)
# Local development: http://127.0.0.1:8002
# Production (deploy branch): your Render backend URL
BACKEND_URL=http://127.0.0.1:8002

# Backend API key (server-side — never exposed to browser)
BACKEND_API_KEY=your_finrag_api_key_here

# Public API URL (used by client-side health check only)
# Local development: http://127.0.0.1:8002
# Production: your Render backend URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8002

# Public API key (used by client-side health check only)
NEXT_PUBLIC_API_KEY=your_finrag_api_key_here
